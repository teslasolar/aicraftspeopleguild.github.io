{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "udtType": "AndroidAtom.SensorReading",
  "version": "1.0.0",
  "description": "One live reading from an android.hardware.Sensor. values[] length varies by sensor type (accelerometer=3, light=1, rotation_vector=5). Published to the MQTT bus at topic sensor.<kind>.value on every delivery.",
  "parameters": {
    "kind":         { "dataType": "String", "required": true, "description": "stable slug: accelerometer | gyroscope | light | proximity | pressure | ..." },
    "hwType":       { "dataType": "Number", "description": "Sensor.TYPE_* constant from android.hardware.Sensor" },
    "name":         { "dataType": "String" },
    "vendor":       { "dataType": "String" },
    "unit":         { "dataType": "String" },
    "resolution":   { "dataType": "Number" },
    "maxRange":     { "dataType": "Number" },
    "minDelayUs":   { "dataType": "Number" },
    "permission":   { "dataType": "String", "description": "android.permission.* required, empty if none" },
    "values":       { "dataType": "JSON",   "description": "array of floats from SensorEvent.values" },
    "accuracy":     { "dataType": "String", "enum": ["HIGH","MEDIUM","LOW","UNRELIABLE","NONE"] },
    "ts":           { "dataType": "DateTime" }
  },
  "tagRoot": "sensor.{kind}"
}
