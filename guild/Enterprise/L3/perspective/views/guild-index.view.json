        "type": "acg.dock.north",
        "props": {},
        "children": [
          { "meta": { "name": "Emblem"   }, "type": "acg.display.emblem",  "props": { "text": "⚒ GUILD OPS ⚒" }, "children": [] },
          { "meta": { "name": "Title"    }, "type": "acg.display.heading", "props": { "level": 1, "text": "Guild Operator Dashboard" }, "children": [] },
          { "meta": { "name": "Subtitle" }, "type": "acg.display.text",    "props": { "text": "Internal infrastructure view — apps, SCADA telemetry, ISA-95 levels, build state. Not the public-facing site." }, "children": [] },
          { "meta": { "name": "PublicBack" }, "type": "acg.display.html", "props": { "html": "<div class=\"back-link\"><a href=\"../index.html\">← Public Guild Site</a></div>" }, "children": [] }
        ]
