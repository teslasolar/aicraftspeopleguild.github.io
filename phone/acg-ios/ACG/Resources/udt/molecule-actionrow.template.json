{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "udtType": "AndroidMolecule.ActionRow",
  "version": "1.0.0",
  "description": "Horizontal row of AndroidAtom.ActionButton atoms with consistent spacing. Optionally shows a trailing CircularProgressIndicator when `busy` is true.",
  "composes": ["AndroidAtom.ActionButton"],
  "parameters": {
    "buttons": { "dataType": "JSON", "required": true,
                 "description": "array of AndroidAtom.ActionButton parameters" },
    "busy":    { "dataType": "Boolean", "default": false }
  }
}
