{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "udtType": "AndroidAtom.StatusLine",
  "version": "1.0.0",
  "description": "One line of status text. severity picks the color (ok=green, err=red, info=dim).",
  "parameters": {
    "text":     { "dataType": "String", "required": true },
    "severity": { "dataType": "String", "enum": ["ok", "err", "info", "warn"], "default": "info" }
  }
}
