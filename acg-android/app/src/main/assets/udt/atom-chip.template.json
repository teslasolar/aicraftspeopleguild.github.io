{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "udtType": "AndroidAtom.Chip",
  "version": "1.0.0",
  "description": "Small pill badge (#nnn, tag name, etc). Non-interactive by default; onClick makes it an AssistChip.",
  "parameters": {
    "label": { "dataType": "String", "required": true },
    "color": { "dataType": "String", "enum": ["primary","secondary","error","surface"], "default": "surface" }
  }
}
