{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acg:scada/spot/beats",
  "title": "SPOT patrol manifest",
  "description": "List of beats SPOT walks each sweep. Each entry names a beat in spot.beats.REGISTRY plus the cfg dict passed to it.",
  "type": "object",
  "additionalProperties": true,
  "required": ["beats"],
  "properties": {
    "$schema":     { "type": "string" },
    "description": { "type": "string" },
    "beats": {
      "type": "array",
      "items": { "$ref": "#/$defs/beat" }
    }
  },
  "$defs": {
    "beat": {
      "type": "object",
      "required": ["beat"],
      "additionalProperties": false,
      "properties": {
        "beat": {
          "type": "string",
          "enum": [
            "origin-heartbeat",
            "link-health",
            "html-scan",
            "manifesto-hash",
            "manifesto-sheet",
            "isa-61131"
          ]
        },
        "cfg": {
          "type": "object",
          "description": "Beat-specific config. Unknown keys are ignored by the beat.",
          "additionalProperties": true,
          "properties": {
            "urls":     { "type": "array", "items": { "type": "string", "format": "uri" } },
            "pages":    { "type": "array", "items": { "type": "string" } },
            "path":     { "type": "string" },
            "origin":   { "type": "string", "format": "uri" },
            "target":   { "type": "string", "format": "uri" },
            "timeout":  { "type": "number", "minimum": 1, "maximum": 60 },
            "slow_ms":  { "type": "integer", "minimum": 100 },
            "sheet_id": { "type": "string" },
            "gid":      { "type": ["string", "integer"] },
            "min_rows": { "type": "integer", "minimum": 0 },
            "force_rebaseline": { "type": "boolean" }
          }
        }
      }
    }
  }
}
