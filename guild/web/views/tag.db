    {
      "file": "white-paper-article.view.json",
      "udtType": "View",
      "id": "white-paper-article",
      "body": {
        "udtType": "View",
        "parameters": {
          "name": "white-paper-article",
          "description": "Individual white paper article page",
          "root": {
            "type": "PageShell",
            "props": {
              "title": "{{ paper.parameters.title }}",
              "subtitle": "{{ paper.parameters.summary }}",
              "bodyClass": "page-white-paper",
              "stylesheets": [
                "style/main.css"
              ],
              "eyebrow": "ACG White Paper",
              "backHref": "../white-papers.html",
              "backLabel": "Back to White Papers",
              "meta": [
                "{{ paper.parameters.authors.0 }}",
                "{{ paper.parameters.publication_date }}",
                "{{ paper.parameters.doc_number }}"
              ]
            },
            "children": [
              {
                "type": "ArticleNav",
                "props": {
                  "sections": "{{ article.sections }}"
                }
              },
              {
                "type": "IntroPanel",
                "props": {
                  "cssVariant": "lead",
                  "content": "{{ article.lead }}"
                }
              },
              {
                "type": "ArticleBody",
                "repeat": {
                  "source": "article.sections",
                  "as": "section",
                  "template": {
                    "type": "ArticleSection",
                    "props": {
                      "id": "{{ section.id }}",
                      "title": "{{ section.label }}"
                    },
                    "children": "{{ section.content }}"
                  }
                }
              },
              {
                "type": "ClosingStatement",
                "props": {
                  "content": "{{ article.closing }}",
                  "paperMark": "{{ article.paper_mark }}"
                }
              },
              {
                "type": "CTASection",
                "props": {
                  "heading": "Continue Reading",
                  "primaryText": "Back to White Papers",
                  "primaryHref": "../white-papers.html",
                  "secondaryText": "Back to Home",
                  "secondaryHref": "#/"
                }
              }
            ]
          }
        },
        "tags": {
          "id": "white-paper-article",
          "component_ids": [
            "page-shell",
            "article-nav",
            "intro-panel",
            "article-section",
            "closing-statement",
            "cta-section",
            "callout",
            "figure-block",
            "code-block",
            "pull-quote"
          ],
          "data_sources": [
            "white-papers/udts/instances/:slug.json"
          ],
          "schema_version": "1.0.0"
        }
      }
    },
    {
      "file": "white-paper-index.view.json",
      "udtType": "View",
      "id": "white-paper-index",
      "body": {
        "udtType": "View",
        "parameters": {
          "name": "white-paper-index",
          "description": "White papers listing page with card grid",
          "root": {
            "type": "PageShell",
            "props": {
              "title": "White Papers",
              "subtitle": "{{ page.subtitle }}",
              "bodyClass": "page-white-papers",
              "stylesheets": [
                "style/main.css"
              ],
              "backHref": "../../index.html",
              "backLabel": "Back to Home"
            },
            "children": [
              {
                "type": "IntroPanel",
                "props": {
                  "content": "{{ page.intro }}"
                }
              },
              {
                "type": "CardGrid",
                "props": {
                  "heading": "Available Papers",
                  "subheading": "{{ page.grid_subheading }}",
                  "gridClass": "papers-grid",
                  "shellClass": "papers-shell"
                },
                "repeat": {
                  "source": "papers",
                  "as": "paper",
                  "template": {
                    "type": "PaperCard",
                    "props": {
                      "title": "{{ paper.parameters.title }}",
                      "authors": "{{ paper.parameters.authors }}",
                      "date": "{{ paper.parameters.publication_date }}",
                      "docNumber": "{{ paper.parameters.doc_number }}",
                      "summary": "{{ paper.parameters.summary }}",
                      "href": "{{ paper.parameters.site_href }}",
                      "status": "{{ paper.parameters.status }}",
                      "tags": "{{ paper.parameters.tags }}"
                    }
                  }
                }
              },
              {
                "type": "CTASection",
                "props": {
                  "heading": "Contribute a Paper",
                  "description": "Drop a Markdown or CSV file in white-papers/originals/ and run the ingest pipeline.",
                  "primaryText": "Back to White Papers",
                  "primaryHref": "#",
                  "secondaryText": "Back to Home",
                  "secondaryHref": "../../index.html"
                }
              }
            ]
          }
        },
        "tags": {
          "id": "white-paper-index",
          "component_ids": [
            "page-shell",
            "intro-panel",
            "card-grid",
            "paper-card",
            "cta-section"
          ],
          "data_sources": [
            "white-papers/index.json"
          ],
          "schema_version": "1.0.0"
        }
      }
    }
  ]
}
