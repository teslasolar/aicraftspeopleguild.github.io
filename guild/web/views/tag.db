    {
      "file": "member-profile.view.json",
      "udtType": "View",
      "id": "member-profile",
      "body": {
        "udtType": "View",
        "parameters": {
          "name": "member-profile",
          "description": "Individual Guild member profile page",
          "root": {
            "type": "PageShell",
            "props": {
              "title": "{{ member.parameters.name }}",
              "subtitle": "{{ member.parameters.title }}",
              "bodyClass": "page-member-profile",
              "stylesheets": [
                "style/main.css",
                "style/member-profile.css"
              ],
              "eyebrow": "ACG Member",
              "backHref": "#/members",
              "backLabel": "Back to Members"
            },
            "children": [
              {
                "type": "IntroPanel",
                "props": {
                  "content": "{{ member.parameters.bio }}"
                }
              },
              {
                "type": "FigureBlock",
                "when": "{{ member.parameters.avatar_href }}",
                "props": {
                  "src": "{{ member.parameters.avatar_href }}",
                  "alt": "{{ member.parameters.name }} portrait",
                  "caption": ""
                }
              },
              {
                "type": "BadgeRow",
                "when": "{{ member.parameters.expertise_tags }}",
                "props": {
                  "items": "{{ member.parameters.expertise_tags }}"
                }
              },
              {
                "type": "CTASection",
                "props": {
                  "heading": "Explore More",
                  "primaryText": "Back to Members",
                  "primaryHref": "#/members",
                  "secondaryText": "Back to Home",
                  "secondaryHref": "#/"
                }
              }
            ]
          }
        },
        "tags": {
          "id": "member-profile",
          "component_ids": [
            "page-shell",
            "intro-panel",
            "figure-block",
            "badge-row",
            "cta-section"
          ],
          "data_sources": [
            "members/udts/instances/:slug.json"
          ],
          "schema_version": "1.0.0"
        }
      }
    },
    {
      "file": "members-index.view.json",
      "udtType": "View",
      "id": "members-index",
      "body": {
        "udtType": "View",
        "parameters": {
          "name": "members-index",
          "description": "Members directory page with profile cards",
          "root": {
            "type": "PageShell",
            "props": {
              "title": "Guild Members",
              "subtitle": "{{ page.subtitle }}",
              "bodyClass": "page-members",
              "stylesheets": [
                "style/main.css"
              ],
              "backHref": "#/",
              "backLabel": "Back to Home"
            },
            "children": [
              {
                "type": "IntroPanel",
                "props": {
                  "content": "{{ page.intro }}"
                }
              },
              {
                "type": "CardGrid",
                "props": {
                  "heading": "Current Members",
                  "gridClass": "members-list",
                  "shellClass": "members-shell"
                },
                "repeat": {
                  "source": "members",
                  "as": "member",
                  "template": {
                    "type": "MemberCard",
                    "props": {
                      "name": "{{ member.parameters.name }}",
                      "role": "{{ member.parameters.role }}",
                      "title": "{{ member.parameters.title }}",
                      "bio": "{{ member.parameters.bio }}",
                      "summary": "{{ member.parameters.summary }}",
                      "avatarSrc": "{{ member.parameters.avatar_href }}",
                      "avatarAlt": "{{ member.parameters.name }} portrait",
                      "profileHref": "members/{{ member.tags.slug }}/",
                      "expertiseTags": "{{ member.parameters.expertise_tags }}"
                    }
                  }
                }
              },
              {
                "type": "CTASection",
                "props": {
                  "heading": "Join the Guild",
                  "primaryText": "Read the Charter",
                  "primaryHref": "charter.html",
                  "secondaryText": "Back to Home",
                  "secondaryHref": "#/"
                }
              }
            ]
          }
        },
        "tags": {
          "id": "members-index",
          "component_ids": [
            "page-shell",
            "intro-panel",
            "card-grid",
            "member-card",
            "cta-section"
          ],
          "data_sources": [
            "members/index.json"
          ],
          "schema_version": "1.0.0"
        }
      }
    },
