{
  "udtType": "Tool",
  "parameters": {
    "id": "gh-tag:write",
    "name": "Write a GitHub-Issue tag",
    "description": "Update (or create) a tag backed by a GitHub Issue. Appends a comment with the new Value/Quality/Timestamp AND updates the issue body so readers pick up the latest without paging history. Requires GITHUB_TOKEN env var.",
    "category": "command",
    "entry": "guild/Enterprise/L2/lib/gh_tag.py:write",
    "language": "python",
    "inputs": [
      {"name":"path","type":"String","required":true},
      {"name":"value","type":"String","required":false},
      {"name":"quality","type":"String","required":false,"default":"good"},
      {"name":"type","type":"String","required":false,"default":"String"},
      {"name":"description","type":"String","required":false}
    ],
    "outputs": [{"name":"result","type":"JSON"}],
    "adapters": ["CliAdapter","McpAdapter","LoggerWrapper"],
    "tags": ["tag","github","dynamic","write"],
    "mcp": {
      "mcp_name":"gh_tag_write",
      "input_schema":{
        "type":"object",
        "properties":{
          "path":{"type":"string"},"value":{"type":"string"},
          "quality":{"type":"string"},"type":{"type":"string"},
          "description":{"type":"string"}
        },
        "required":["path"]
      }
    }
  },
  "tags": { "id": "gh-tag-write", "schema_version": "1.0.0" }
}
