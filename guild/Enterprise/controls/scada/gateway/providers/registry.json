{
  "§": "P",
  "name": "ACG · provider registry",
  "desc": "Tag-provider registry hosted by the SCADA gateway. One row per subsystem; each row points at the Jython 2.7 provider module plus its declarative UDT + tag catalogs. The browser runtime at /controls/scada/gateway/scripts/scada/providers.js mirrors this list.",
  "host": "controls/scada/gateway/",
  "registry_path": "controls/scada/gateway/providers/registry.json",

  "runtime": {
    "jython":  "2.7",
    "browser": "ES modules",
    "bridge":  "BroadcastChannel('acg-mesh')"
  },

  "subsystems": [
    {
      "id": "💬 chat",
      "dir": "controls/hmi/chat/",
      "provider": "controls/hmi/chat/provider.py",
      "udts": "controls/hmi/chat/udts.json",
      "tags": "controls/hmi/chat/tags.json",
      "templates": "controls/hmi/chat/templates/",
      "screen": "controls/hmi/chat/index.html",
      "browser": ["controls/scada/gateway/scripts/config.js", "controls/scada/gateway/scripts/p2p.js", "controls/scada/gateway/scripts/peers.js", "controls/scada/gateway/scripts/chat.js"],
      "namespaces": ["chat", "room", "tracker", "peers", "signal"]
    },
    {
      "id": "🔑 auth",
      "dir": "controls/scada/gateway/auth/",
      "provider": "controls/scada/gateway/auth/provider.py",
      "udts": "controls/scada/gateway/auth/udts.json",
      "tags": "controls/scada/gateway/auth/tags.json",
      "browser": ["controls/scada/gateway/scripts/auth.js"],
      "host": "controls/scada/gateway/",
      "subProviders": [
        "controls/scada/gateway/auth/webrtc/",
        "controls/scada/gateway/auth/webtorrent/",
        "controls/scada/gateway/auth/discord/",
        "controls/scada/gateway/auth/github/",
        "controls/scada/gateway/auth/google/"
      ],
      "namespaces": ["auth"]
    },
    {
      "id": "📡 auth.webrtc",
      "dir": "controls/scada/gateway/auth/webrtc/",
      "provider": "controls/scada/gateway/auth/webrtc/provider.py",
      "udts": "controls/scada/gateway/auth/webrtc/udts.json",
      "tags": "controls/scada/gateway/auth/webrtc/tags.json",
      "browser": ["controls/scada/gateway/scripts/config.js", "controls/scada/gateway/scripts/p2p.js"],
      "namespaces": ["auth.webrtc"]
    },
    {
      "id": "🌊 auth.webtorrent",
      "dir": "controls/scada/gateway/auth/webtorrent/",
      "provider": "controls/scada/gateway/auth/webtorrent/provider.py",
      "udts": "controls/scada/gateway/auth/webtorrent/udts.json",
      "tags": "controls/scada/gateway/auth/webtorrent/tags.json",
      "browser": ["controls/scada/gateway/scripts/config.js", "controls/scada/gateway/scripts/p2p.js"],
      "namespaces": ["auth.webtorrent"]
    },
    {
      "id": "🖥️ scada",
      "dir": "controls/scada/",
      "provider": "controls/scada/provider.py",
      "udts":     "controls/scada/udts.json",
      "tags":     "controls/scada/tags.json",
      "specs":    ["controls/scada/00-legend.json", "controls/scada/01-master.json", "controls/scada/02-chat.json", "controls/scada/03-scada.json", "controls/scada/04-sandbox.json"],
      "programs": "controls/scada/programs/",
      "browser":  ["controls/scada/gateway/scripts/scada/tags.js", "controls/scada/gateway/scripts/scada/providers.js", "controls/scada/gateway/scripts/scada/monitor.js", "controls/scada/gateway/scripts/scada/udt.js"],
      "namespaces": ["sys", "version"]
    },
    {
      "id": "⚠ errors",
      "dir": "controls/scada/errors/",
      "provider": "controls/scada/errors/provider.py",
      "udts": "controls/scada/errors/udts.json",
      "tags": "controls/scada/errors/tags.json",
      "browser": ["controls/scada/gateway/scripts/errors.js"],
      "viewer": "gateway-log.html",
      "namespaces": ["errors"]
    },
    {
      "id": "🗄️ db",
      "dir": "controls/db/",
      "tags": "controls/db/tags.json",
      "viewer": "controls/db/index.html",
      "catalog": "controls/db/tags.sqlite",
      "catalog_schema": "controls/db/sql/schema.sql",
      "catalog_seed": "controls/db/sql/seed.sql",
      "build": "controls/db/build.py",
      "desc": "Canonical tag snapshot (tags.json) read by the README HMI + shields.io badges, plus the indexed catalog (tags.sqlite) rebuilt by controls/db/build.py from every manifest in the project. GitHub Action .github/workflows/rebuild-db.yml rebuilds on every manifest change.",
      "namespaces": ["*"]
    },
    {
      "id": "🖼 hmi",
      "dir": "controls/hmi/",
      "provider": "controls/hmi/provider.py",
      "udts":     "controls/hmi/udts.json",
      "tags":     "controls/hmi/tags.json",
      "standards":["controls/docs/standards/konomi/isa101/"],
      "namespaces": ["hmi"]
    },
    {
      "id": "🔧 plc",
      "dir": "controls/plc/",
      "provider": "controls/plc/provider.py",
      "udts":     "controls/plc/udts.json",
      "tags":     "controls/plc/tags.json",
      "templates":"controls/plc/git/",
      "standards":["controls/docs/standards/gitplc/"],
      "namespaces": ["plc"]
    },
    {
      "id": "🧪 sandbox",
      "dir": "controls/sandbox/",
      "provider": "controls/sandbox/provider.py",
      "udts": "controls/sandbox/udts.json",
      "tags": "controls/sandbox/tags.json",
      "browser": ["controls/scada/gateway/scripts/sandbox-bridge.js", "controls/sandbox/shared/mesh-bridge.js", "controls/sandbox/**"],
      "tools": [
        {"id":"🧠 web-llm",    "dir":"controls/sandbox/web-llm/",    "status":"ready"},
        {"id":"🖍 whiteboard", "dir":"controls/sandbox/whiteboard/", "status":"ready",
         "namespaces":["sandbox.whiteboard"]}
      ],
      "namespaces": ["sandbox"]
    }
  ],

  "和": true
}
