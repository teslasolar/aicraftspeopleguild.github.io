{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "udtType": "AndroidApi",
  "version": "1.0.0",
  "description": "A remote HTTP endpoint the app reads/writes. Mirrors the server-side Api UDT; url supports ${SITE_BASE} for self-detected Pages hosts.",
  "parameters": {
    "id":          { "dataType": "String", "required": true },
    "name":        { "dataType": "String", "required": true },
    "url":         { "dataType": "String", "required": true },
    "method":      { "dataType": "String", "enum": ["GET","HEAD","POST","PATCH","DELETE"], "default": "GET" },
    "auth":        { "dataType": "String", "enum": ["none","github_token","bearer"], "default": "none" },
    "content":     { "dataType": "String", "enum": ["json","text"], "default": "json" },
    "output_tag":  { "dataType": "String" }
  },
  "tagRoot": "android.api.{id}"
}
