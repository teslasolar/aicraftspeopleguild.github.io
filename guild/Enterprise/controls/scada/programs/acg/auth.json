{
  "§": "2.5",
  "🏗️": "🔑",
  "name": "auth",
  "module": "controls/scada/gateway/scripts/auth.js",

  "📦": {
    "profile":   "🔑? (Profile UDT from localStorage)",
    "listeners": "Set<(profile)→void>"
  },

  "🏗️": {
    "Profile": { "provider":"e[discord|github]", "id":"s", "username":"s", "avatar":"s" }
  },

  "→": [
    { "name": "load",           "out": "🔑?",               "flow": "JSON.parse(localStorage.acg.profile) ∨ ∅" },
    { "name": "save",           "in": "p:🔑?",              "flow": "localStorage.set ⊕ publishProfile ⊕ listeners(p) ⊕ paint()" },
    { "name": "publishProfile", "flow": "AUTH.write(profile,🏗️Profile) ⊕ AUTH.write(signedIn,b)" },
    { "name": "discordLogin",   "flow": "→ https://discord.com/oauth2/authorize?response_type=token (implicit grant, pure browser)" },
    { "name": "discordFinish",  "in": "token:s",            "flow": "GET /api/users/@me → save(🏗️Profile)" },
    { "name": "githubLogin",    "flow": "POST {proxyUrl}/device/code → open verification_uri ⊕ prompt(code) ⊕ poll /access_token" },
    { "name": "githubFinish",   "in": "token:s",            "flow": "GET api.github.com/user → save(🏗️Profile)" },
    { "name": "handleRedirect", "flow": "if location.hash has access_token → state-check ⊕ discordFinish" },
    { "name": "paint",          "flow": "rebuild #auth nav (logged-in chip ∨ GitHub/Discord buttons)" },
    { "name": "startAuth",      "flow": "paint() ⊕ handleRedirect()" },
    { "name": "onProfileChange","in": "fn",                 "out": "unsub", "flow": "listeners.add(fn)" },
    { "name": "logout",         "flow": "save(∅)" }
  ],

  "↑🖥️": ["auth.profile", "auth.signedIn"],
  "↓🖥️": [],

  "和": true
}
