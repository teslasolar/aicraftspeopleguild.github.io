    "stylesheets": ["web/style/main.css"],
    "headExtra": "<style>body.page-guild-operator{background:#faf6f0;}.op-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem;margin:1.5rem 0;}.op-card{background:white;border-left:3px solid var(--color-bronze,#A67C52);padding:1rem 1.25rem;box-shadow:0 2px 6px rgba(0,0,0,.05);}.op-card h3{margin-top:0;font-size:1.05rem;color:var(--color-rust,#C84B31);}.op-card ul{padding-left:1.25rem;margin:.5rem 0;font-size:.92rem;}.op-card a{color:var(--color-ink,#1A1614);}.op-note{font-size:.85rem;color:#666;margin-top:.5rem;}.op-badge{display:inline-block;padding:.15rem .5rem;background:rgba(26,92,76,.1);color:#1a5c4c;border-radius:3px;font-size:.75rem;margin-left:.35rem;font-family:'Courier Prime',monospace;}</style>"
  },
  "params": {
    "title": "Guild Operator Dashboard"
  },
  "propConfig": {},
